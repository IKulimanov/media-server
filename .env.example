# =============================================================
#  .env — переменные окружения для media-stack
#  Скопировать: cp .env.example .env
#  Затем заполнить все значения ниже
# =============================================================

# -------------------------------------------------------------
# СИСТЕМА
# -------------------------------------------------------------

# Временная зона
# Полный список: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Bishkek

# UID и GID пользователя от которого запускаются контейнеры
# Узнать свои значения: id -u && id -g
PUID=1000
PGID=1000

# Имя хоста (отображается в уведомлениях Notifiarr)
HOSTNAME=mediaserver

# -------------------------------------------------------------
# ПУТИ К ДАННЫМ
# -------------------------------------------------------------

# Корневая папка для всех медиаданных
# ⚠️ ВАЖНО: DATA_ROOT должен быть на одном разделе диска!
# Hardlink работает только в пределах одного раздела.
# Если /data и /home на разных разделах — hardlink не будет работать.
DATA_ROOT=/data

# Папка для конфигов всех сервисов
CONFIG_ROOT=/data/configs

# -------------------------------------------------------------
# TELEGRAM УВЕДОМЛЕНИЯ
# -------------------------------------------------------------

# Как создать бота:
# 1. Открыть @BotFather в Telegram
# 2. Написать /newbot → дать имя → получить токен
# 3. Написать своему боту любое сообщение
# 4. Открыть: https://api.telegram.org/bot<TOKEN>/getUpdates
#    Найти "chat":{"id": XXXXXXXX} — это твой CHAT_ID

TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789
